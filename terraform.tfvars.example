# Copy this file to terraform.tfvars and fill in your values.
# DO NOT commit terraform.tfvars to git (it's in .gitignore).

project_name      = "my-openwebui"       # Used for resource naming and the public DNS label
environment       = "demo"
location          = "eastus"
letsencrypt_email = "you@example.com"    # Required for Let's Encrypt TLS certificate

# Optional overrides — defaults are set in variables.tf
# openai_model_name          = "gpt-4o"
# spot_instances             = false
# user_node_vm_size          = "Standard_D2s_v3"
# user_node_count            = 1
# kubernetes_version         = "1.34.4"
# traefik_chart_version      = "39.0.7"
# cert_manager_chart_version = "v1.20.1"
# open_webui_chart_version   = "13.3.1"

tags = {
  Project     = "AKS-OpenWebUI"
  Environment = "Demo"
  ManagedBy   = "Terraform"
}
