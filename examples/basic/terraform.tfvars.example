# Copy to terraform.tfvars and fill in your values.
# DO NOT commit terraform.tfvars to git.

# Used for all resource names and the app domain:
#   https://<project_name>.<location>.cloudapp.azure.com
project_name = "my-openwebui"

environment = "demo"
location    = "eastus"

# Required — Let's Encrypt uses this for cert expiry notices
letsencrypt_email = "you@example.com"

tags = {
  ManagedBy = "Terraform"
  Owner     = "YourName"
}
