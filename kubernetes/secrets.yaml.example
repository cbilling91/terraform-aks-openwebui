# Example Kubernetes secret for Azure OpenAI API key
# DO NOT commit actual secrets to git

# The deployment script will create this secret automatically using kubectl:
# kubectl create secret generic azure-openai-secret \
#   --from-literal=api-key="YOUR_AZURE_OPENAI_API_KEY"

# If you need to create it manually, use this template:
# 1. Copy this file to secrets.yaml
# 2. Replace YOUR_AZURE_OPENAI_API_KEY_BASE64 with your base64-encoded API key
#    (Run: echo -n "YOUR_API_KEY" | base64)
# 3. Apply: kubectl apply -f secrets.yaml
# 4. Delete secrets.yaml after applying (never commit it)

apiVersion: v1
kind: Secret
metadata:
  name: azure-openai-secret
  namespace: default
type: Opaque
data:
  api-key: YOUR_AZURE_OPENAI_API_KEY_BASE64
